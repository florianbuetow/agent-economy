#!/usr/bin/env bash
# Composite hook: chains beads hook + CI gate

REPO_ROOT="$(git rev-parse --show-toplevel)"
BEADS_HOOK="${REPO_ROOT}/.beads/hooks/pre-push"

if [ -x "${BEADS_HOOK}" ]; then
    "${BEADS_HOOK}" "$@" || exit $?
fi

# Block push if CI fails
cd "${REPO_ROOT}"
printf "\033[0;34m--- Running CI before push ---\033[0m\n"
if ! just ci-quiet; then
    printf "\033[0;31m✗ CI failed — push blocked\033[0m\n" >&2
    exit 1
fi
